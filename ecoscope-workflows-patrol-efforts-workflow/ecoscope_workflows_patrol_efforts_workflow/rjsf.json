    "Filter Data": {
      "type": "object",
      "description": "Spatial and trajectory filters applied to BOTH the patrol tracks and the events.",
      "ecoscope:task_group": true,
      "properties": {
        "patrol_filters": {
          "additionalProperties": false,
          "properties": {
            "bounding_box": {
              "allOf": [
                {
                  "$ref": "#/$defs/BoundingBox"
                }
              ],
              "default": {
                "min_y": -90.0,
                "max_y": 90.0,
                "min_x": -180.0,
                "max_x": 180.0
              },
              "title": "Bounding Box",
              "description": "Only include patrol tracks and events whose coordinates fall inside this bounding box.",
              "ecoscope:advanced": true
            },
            "filter_point_coords": {
              "default": [
                {
                  "y": 90.0,
                  "x": 180.0
                },
                {
                  "y": 0.0,
                  "x": 0.0
                },
                {
                  "y": 1.0,
                  "x": 1.0
                }
              ],
              "items": {
                "$ref": "#/$defs/Coordinate"
              },
              "title": "Filter Exact Point Coordinates",
              "type": "array",
              "description": "Exclude tracks and events recorded at these exact coordinates (e.g. known bad GPS fixes).",
              "ecoscope:advanced": true
            },
            "trajectory_segment_filter": {
              "allOf": [
                {
                  "$ref": "#/$defs/TrajectorySegmentFilter"
                }
              ],
              "default": {
                "min_length_meters": 0.001,
                "max_length_meters": 100000,
                "min_time_secs": 1,
                "max_time_secs": 172800,
                "min_speed_kmhr": 0.01,
                "max_speed_kmhr": 500
              },
              "title": "Trajectory Filter",
              "description": "Drop trajectory segments outside these length / time / speed bounds (applies to the patrol tracks only).",
              "ecoscope:advanced": true
            }
          },
          "type": "object",
          "required": [],
          "title": ""
        }
      }
    },
    "Patrol Effort Summary": {
      "type": "object",
      "description": "Per-category patrol metrics. Choose the aggregator column and which metrics to show.",
      "ecoscope:task_group": true,
      "properties": {
        "summary_table_df": {
          "additionalProperties": false,
          "properties": {
            "summary_params": {
              "items": {
                "discriminator": {
                  "mapping": {
                    "count": "#/$defs/TallySummaryParam",
                    "max": "#/$defs/NumericSummaryParam",
                    "mean": "#/$defs/NumericSummaryParam",
                    "median": "#/$defs/NumericSummaryParam",
                    "merged_coverage_area": "#/$defs/CoverageSummaryParam",
                    "min": "#/$defs/NumericSummaryParam",
                    "night_day_ratio": "#/$defs/NightDayRatioSummaryParam",
                    "nunique": "#/$defs/TallySummaryParam",
                    "sum": "#/$defs/NumericSummaryParam",
                    "unique": "#/$defs/TallySummaryParam",
                    "unmerged_coverage_area": "#/$defs/CoverageSummaryParam"
                  },
                  "propertyName": "aggregator"
                },
                "oneOf": [
                  {
                    "$ref": "#/$defs/TallySummaryParam"
                  },
                  {
                    "$ref": "#/$defs/NumericSummaryParam"
                  },
                  {
                    "$ref": "#/$defs/CoverageSummaryParam"
                  },
                  {
                    "$ref": "#/$defs/NightDayRatioSummaryParam"
                  }
                ]
              },
              "title": "Summary Metrics",
              "type": "array",
              "description": "Columns shown in the summary table. Add or remove rows to customize. 'Merged/Unmerged Area Covered' use the Swath Width on the row.",
              "default": [
                {
                  "display_name": "Patrol Count",
                  "aggregator": "nunique",
                  "column": "patrol_id"
                },
                {
                  "display_name": "Total Distance (km)",
                  "aggregator": "sum",
                  "column": "dist_meters",
                  "original_unit": "m",
                  "new_unit": "km",
                  "decimal_places": 1
                },
                {
                  "display_name": "Total Duration (hrs)",
                  "aggregator": "sum",
                  "column": "timespan_seconds",
                  "original_unit": "s",
                  "new_unit": "h",
                  "decimal_places": 1
                },
                {
                  "display_name": "Patrol Days",
                  "aggregator": "nunique",
                  "column": "segment_start_date"
                },
                {
                  "display_name": "Merged Area Covered (km\u00b2)",
                  "aggregator": "merged_coverage_area",
                  "swath_width_meters": 500.0,
                  "decimal_places": 1
                },
                {
                  "display_name": "Unmerged Area Covered (km\u00b2)",
                  "aggregator": "unmerged_coverage_area",
                  "swath_width_meters": 500.0,
                  "decimal_places": 1
                }
              ]
            },
            "groupby_cols": {
              "default": [
                "patrol_subject"
              ],
              "items": {
                "type": "string",
                "oneOf": [
                  {
                    "const": "patrol_subject",
                    "title": "Patrol Subject"
                  },
                  {
                    "const": "patrol_type__value",
                    "title": "Patrol Type"
                  },
                  {
                    "const": "patrol_status",
                    "title": "Patrol Status"
                  }
                ]
              },
              "title": "Aggregator",
              "type": "array",
              "description": "Column to aggregate (group) summary rows by. Default: patrol subject (ranger). Other options: patrol_type__value, patrol_status."
            }
          },
          "required": [
            "summary_params"
          ],
          "type": "object",
          "title": "Summarize Patrol Effort"
        }
      }
    },
    "Patrol Coverage Map": {
      "type": "object",
      "description": "Grid heatmap of patrol effort, weighted by total time or distance per cell.",
      "ecoscope:task_group": true,
      "properties": {
        "coverage_meshgrid": {
          "additionalProperties": false,
          "properties": {
            "auto_scale_or_custom_cell_size": {
              "anyOf": [
                {
                  "$ref": "#/$defs/AutoScaleGridCellSize"
                },
                {
                  "$ref": "#/$defs/CustomGridCellSize"
                }
              ],
              "default": {
                "auto_scale_or_custom": "Auto-scale"
              },
              "title": "Grid Cell Size",
              "ecoscope:advanced": true
            },
            "crs": {
              "default": "EPSG:3857",
              "title": "Coordinate Reference System",
              "type": "string",
              "description": "The coordinate reference system in which to perform the calculation, must be a valid CRS authority code, for example ESRI:53042",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Coverage Meshgrid"
        },
        "grouped_coverage_density": {
          "additionalProperties": false,
          "properties": {
            "sum_column": {
              "default": "timespan_seconds",
              "title": "Coverage Weighting",
              "type": "string",
              "description": "Weight each grid cell by total patrol time (timespan_seconds) or distance travelled (dist_meters).",
              "enum": [
                "timespan_seconds",
                "dist_meters"
              ]
            }
          },
          "required": [],
          "type": "object",
          "title": "Calculate Patrol Effort per Cell"
        }
      }
    },
    "Event Density Map": {
      "type": "object",
      "description": "Grid heatmap of event counts per cell.",
      "ecoscope:task_group": true,
      "properties": {
        "event_meshgrid": {
          "additionalProperties": false,
          "properties": {
            "auto_scale_or_custom_cell_size": {
              "anyOf": [
                {
                  "$ref": "#/$defs/AutoScaleGridCellSize"
                },
                {
                  "$ref": "#/$defs/CustomGridCellSize"
                }
              ],
              "default": {
                "auto_scale_or_custom": "Auto-scale"
              },
              "title": "Grid Cell Size",
              "ecoscope:advanced": true
            },
            "crs": {
              "default": "EPSG:3857",
              "title": "Coordinate Reference System",
              "type": "string",
              "description": "The coordinate reference system in which to perform the calculation, must be a valid CRS authority code, for example ESRI:53042",
              "ecoscope:advanced": true
            }
          },
          "required": [],
          "type": "object",
          "title": "Event Meshgrid"
        }
      }
    }
  },
  "$defs": {
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "SpatialGrouper": {
      "properties": {
        "spatial_index_name": {
          "title": "Spatial Regions",
          "type": "string"
        }
      },
      "required": [
        "spatial_index_name"
      ],
      "title": "Spatial",
      "type": "object"
    },
    "TemporalGrouper": {
      "properties": {
        "temporal_index": {
          "oneOf": [
            {
              "const": "%Y",
              "title": "Year (example: 2024)"
            },
            {
              "const": "%B",
              "title": "Month (example: September)"
            },
            {
              "const": "%Y-%m",
              "title": "Year and Month (example: 2023-01)"
            },
            {
              "const": "%j",
              "title": "Day of the year as a number (example: 365)"
            },
            {
              "const": "%d",
              "title": "Day of the month as a number (example: 31)"
            },
            {
              "const": "%A",
              "title": "Day of the week (example: Sunday)"
            },
            {
              "const": "%H",
              "title": "Hour (24-hour clock) as number (example: 22)"
            },
            {
              "const": "%Y-%m-%d",
              "title": "Date (example: 2025-01-31)"
            }
          ],
          "title": "Time",
          "type": "string"
        }
      },
      "required": [
        "temporal_index"
      ],
      "title": "Time",
      "type": "object"
    },
    "ValueGrouper": {
      "properties": {
        "index_name": {
          "title": "Category",
          "type": "string"
        }
      },
      "required": [
        "index_name"
      ],
      "title": "Category",
      "type": "object"
    },
    "BoundingBox": {
      "properties": {
        "min_y": {
          "default": -90.0,
