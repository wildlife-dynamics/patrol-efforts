{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Workflow Details"
    },
    "er_client_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Data Source"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Time Range"
    },
    "Patrol and Event Types": {
      "type": "object",
      "description": "Fetch patrols and the events reported during them in one combined query.",
      "ecoscope:task_group": true,
      "properties": {
        "er_patrol_and_events_params": {
          "additionalProperties": false,
          "properties": {
            "patrol_types": {
              "items": {
                "type": "string"
              },
              "title": "Patrol Types",
              "type": "array",
              "description": "Specify the patrol type(s) to analyze (optional). Leave empty to analyze all patrol types.",
              "ecoscope:transform": [
                {
                  "transformer": "EarthRangerEnumResolver",
                  "transformer_kws": {
                    "type": "patrol_type",
                    "depends_on": "properties.er_client_name.properties.data_source.properties.name"
                  }
                }
              ]
            },
            "event_types": {
              "items": {
                "type": "string"
              },
              "title": "Event Types",
              "type": "array",
              "description": "Specify the event type(s) to map (optional). Leave empty to include all event types reported during the selected patrols.",
              "ecoscope:transform": [
                {
                  "transformer": "EarthRangerEnumResolver",
                  "transformer_kws": {
                    "type": "event_type",
                    "depends_on": "properties.er_client_name.properties.data_source.properties.name"
                  }
                }
              ]
            },
            "status": {
              "default": [
                "done"
              ],
              "items": {
                "enum": [
                  "active",
                  "overdue",
                  "done",
                  "cancelled"
                ],
                "type": "string"
              },
              "title": "Patrol Status",
              "type": "array",
              "description": "Choose to analyze patrols with a certain status. If left empty, patrols of all status will be analyzed",
              "uniqueItems": true,
              "ecoscope:advanced": true
            },
            "patrols_overlap_daterange": {
              "default": true,
              "title": "Patrols Overlap Daterange",
              "type": "boolean",
              "description": "Whether or not to include patrols that start or end outside of the time range",
              "ecoscope:advanced": true
            }
          },
          "required": [
            "patrol_types",
            "event_types"
          ],
          "type": "object",
          "title": "Patrol and Event Params"
        }
      }
    },
    "groupers": {
      "additionalProperties": false,
      "properties": {
        "groupers": {
          "default": null,
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/ValueGrouper"
              },
              {
                "$ref": "#/$defs/TemporalGrouper"
              },
              {
                "$ref": "#/$defs/SpatialGrouper"
              }
            ],
            "title": "Group by"
          },
          "title": " ",
          "type": "array",
          "description": "            Specify how the data should be grouped to create the views for your dashboard.\n            This field is optional; if left blank, all the data will appear in a single view.\n            ",
          "ecoscope:transform": [
            {
              "transformer": "EarthRangerEnumResolver",
              "transformer_kws": {
                "type": "spatial_feature_group",
                "depends_on": "properties.er_client_name.properties.data_source.properties.name"
              }
            }
          ]
        }
      },
      "type": "object",
      "required": [],
      "title": "Dashboard Groupers"
    },
    "Patrols & Events Map": {
      "type": "object",
      "description": "Colour the Patrols & Events map layers.",
      "ecoscope:task_group": true,
      "properties": {
        "set_traj_color_column": {
          "additionalProperties": false,
          "properties": {
            "var": {
              "title": "Colour Tracks By",
              "type": "string",
              "default": "patrol_subject",
              "oneOf": [
                {
                  "const": "patrol_subject",
                  "title": "Patrol Subject"
                },
                {
                  "const": "patrol_type__value",
                  "title": "Patrol Type"
                },
                {
                  "const": "patrol_status",
                  "title": "Patrol Status"
                }
              ]
            }
          },
          "required": [
            "var"
          ],
          "type": "object",
          "title": "Track Colour Category"
        },
        "set_event_color_column": {
          "additionalProperties": false,
          "properties": {
            "var": {
              "title": "Colour Events By",
              "type": "string",
              "default": "event_type",
              "oneOf": [
                {
                  "const": "event_type",
                  "title": "Event Type"
                },
                {
                  "const": "event_category",
                  "title": "Event Category"
                }
              ]
            }
          },
          "required": [
            "var"
          ],
          "type": "object",
          "title": "Event Colour Category"
        }
      }
    },
    "base_map_defs": {
