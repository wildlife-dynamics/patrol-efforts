{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Workflow Details"
    },
    "er_client_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Data Source"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Time Range"
    },
    "er_patrol_params": {
      "additionalProperties": false,
      "properties": {
        "patrol_types": {
          "items": {
            "type": "string"
          },
          "title": "Patrol Types",
          "type": "array",
          "description": "Specify the patrol type(s) to analyze (optional). Leave empty to analyze all patrol types."
        },
        "status": {
          "default": [
            "done"
          ],
          "items": {
            "enum": [
              "active",
              "overdue",
              "done",
              "cancelled"
            ],
            "type": "string"
          },
          "title": "Patrol Status",
          "type": "array",
          "description": "Choose to analyze patrols with a certain status. If left empty, patrols of all status will be analyzed",
          "uniqueItems": true,
          "ecoscope:advanced": true
        },
        "patrols_overlap_daterange": {
          "default": true,
          "title": "Patrols Overlap Daterange",
          "type": "boolean",
          "description": "Whether or not to include patrols that start or end outside of the time range",
          "ecoscope:advanced": true
        }
      },
      "required": [
        "patrol_types"
      ],
      "type": "object",
      "title": "Patrol Params"
    },
    "patrol_filters": {
      "additionalProperties": false,
      "properties": {
        "bounding_box": {
          "allOf": [
            {
              "$ref": "#/$defs/BoundingBox"
            }
          ],
          "default": {
            "min_y": -90.0,
            "max_y": 90.0,
            "min_x": -180.0,
            "max_x": 180.0
          },
          "title": "Bounding Box",
          "description": "Only include observations/events inside this bounding box.",
          "ecoscope:advanced": true
        },
        "filter_point_coords": {
          "default": [
            {
              "y": 90.0,
              "x": 180.0
            },
            {
              "y": 0.0,
              "x": 0.0
            },
            {
              "y": 1.0,
              "x": 1.0
            }
          ],
          "items": {
            "$ref": "#/$defs/Coordinate"
          },
          "title": "Filter Exact Point Coordinates",
          "type": "array",
          "description": "Exclude observations/events at these exact coordinates.",
          "ecoscope:advanced": true
        },
        "trajectory_segment_filter": {
          "allOf": [
            {
              "$ref": "#/$defs/TrajectorySegmentFilter"
            }
          ],
          "default": {
            "min_length_meters": 0.001,
            "max_length_meters": 100000,
            "min_time_secs": 1,
            "max_time_secs": 172800,
            "min_speed_kmhr": 0.01,
            "max_speed_kmhr": 500
          },
          "title": "Trajectory Filter",
          "description": "Drop trajectory segments outside these length/time/speed bounds.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Filters"
    },
    "groupers": {
      "additionalProperties": false,
      "properties": {
        "groupers": {
          "default": null,
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/ValueGrouper"
              },
              {
                "$ref": "#/$defs/TemporalGrouper"
              },
              {
                "$ref": "#/$defs/SpatialGrouper"
              }
            ],
            "title": "Group by"
          },
          "title": " ",
          "type": "array",
          "description": "            Specify how the data should be grouped to create the views for your dashboard.\n            This field is optional; if left blank, all the data will appear in a single view.\n            "
        }
      },
      "type": "object",
      "required": [],
      "title": "Group Data"
    },
    "summary_groupby": {
      "additionalProperties": false,
      "properties": {
        "vars": {
          "items": {
            "type": "string"
          },
          "title": "",
          "type": "array"
        }
      },
      "required": [
        "vars"
      ],
      "type": "object",
      "title": "Aggregator"
    },
    "summary_metrics": {
      "additionalProperties": false,
      "properties": {
        "metrics": {
          "default": [
            {
              "metric": "patrol_count"
            },
            {
              "metric": "total_distance",
              "unit": "km"
            },
            {
              "metric": "total_duration",
              "unit": "h"
            },
            {
              "metric": "patrol_days"
            },
            {
              "metric": "area_covered_merged",
              "swath_width_meters": 500.0
            },
            {
              "metric": "area_covered_unmerged",
              "swath_width_meters": 500.0
            }
          ],
          "items": {
            "discriminator": {
              "mapping": {
                "area_covered_merged": "#/$defs/MergedAreaCoveredMetric",
                "area_covered_unmerged": "#/$defs/UnmergedAreaCoveredMetric",
                "custom": "#/$defs/CustomMetric",
                "patrol_count": "#/$defs/PatrolCountMetric",
                "patrol_days": "#/$defs/PatrolDaysMetric",
                "total_distance": "#/$defs/TotalDistanceMetric",
                "total_duration": "#/$defs/TotalDurationMetric"
              },
              "propertyName": "metric"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/PatrolCountMetric"
              },
              {
                "$ref": "#/$defs/PatrolDaysMetric"
              },
              {
                "$ref": "#/$defs/TotalDistanceMetric"
              },
              {
                "$ref": "#/$defs/TotalDurationMetric"
              },
              {
                "$ref": "#/$defs/MergedAreaCoveredMetric"
              },
              {
                "$ref": "#/$defs/UnmergedAreaCoveredMetric"
              },
              {
                "$ref": "#/$defs/CustomMetric"
              }
            ]
          },
          "title": "Metrics",
          "type": "array",
          "description": "Metrics shown as columns in the patrol summary table. Add or remove rows to customize."
        }
      },
      "type": "object",
      "required": [],
      "title": "Summary Metrics"
    }
  },
  "$defs": {
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "BoundingBox": {
      "properties": {
        "min_y": {
          "default": -90.0,
          "ecoscope:advanced": true,
          "title": "Min Latitude",
          "type": "number"
        },
        "max_y": {
          "default": 90.0,
          "ecoscope:advanced": true,
          "title": "Max Latitude",
          "type": "number"
        },
        "min_x": {
          "default": -180.0,
          "ecoscope:advanced": true,
          "title": "Min Longitude",
          "type": "number"
        },
        "max_x": {
          "default": 180.0,
          "ecoscope:advanced": true,
          "title": "Max Longitude",
          "type": "number"
        }
      },
      "title": "BoundingBox",
      "type": "object"
    },
    "Coordinate": {
      "properties": {
        "y": {
          "description": "Example -0.15293",
          "title": "Latitude",
          "type": "number"
        },
        "x": {
          "description": "Example 37.30906",
          "title": "Longitude",
          "type": "number"
        }
      },
      "required": [
        "y",
        "x"
      ],
      "title": "Coordinate",
      "type": "object"
    },
    "TrajectorySegmentFilter": {
      "properties": {
        "min_length_meters": {
          "default": 0.001,
          "ecoscope:advanced": true,
          "minimum": 0.001,
          "title": "Minimum Segment Length (Meters)",
          "type": "number"
        },
        "max_length_meters": {
          "default": 100000,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Maximum Segment Length (Meters)",
          "type": "number"
        },
        "min_time_secs": {
          "default": 1,
          "ecoscope:advanced": true,
          "minimum": 1,
          "title": "Minimum Segment Duration (Seconds)",
          "type": "number"
        },
        "max_time_secs": {
          "default": 172800,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 1,
          "title": "Maximum Segment Duration (Seconds)",
          "type": "number"
        },
        "min_speed_kmhr": {
          "default": 0.01,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Minimum Segment Speed (Kilometers per Hour)",
          "type": "number"
        },
        "max_speed_kmhr": {
          "default": 500,
          "ecoscope:advanced": true,
          "exclusiveMinimum": 0.001,
          "title": "Maximum Segment Speed (Kilometers per Hour)",
          "type": "number"
        }
      },
      "title": "TrajectorySegmentFilter",
      "type": "object"
    },
    "SpatialGrouper": {
      "properties": {
        "spatial_index_name": {
          "title": "Spatial Regions",
          "type": "string"
        }
      },
      "required": [
        "spatial_index_name"
      ],
      "title": "Spatial",
      "type": "object"
    },
    "TemporalGrouper": {
      "properties": {
        "temporal_index": {
          "oneOf": [
            {
              "const": "%Y",
              "title": "Year (example: 2024)"
            },
            {
              "const": "%B",
              "title": "Month (example: September)"
            },
            {
              "const": "%Y-%m",
              "title": "Year and Month (example: 2023-01)"
            },
            {
              "const": "%j",
              "title": "Day of the year as a number (example: 365)"
            },
            {
              "const": "%d",
              "title": "Day of the month as a number (example: 31)"
            },
            {
              "const": "%A",
              "title": "Day of the week (example: Sunday)"
            },
            {
              "const": "%H",
              "title": "Hour (24-hour clock) as number (example: 22)"
            },
            {
              "const": "%Y-%m-%d",
              "title": "Date (example: 2025-01-31)"
            }
          ],
          "title": "Time",
          "type": "string"
        }
      },
      "required": [
        "temporal_index"
      ],
      "title": "Time",
      "type": "object"
    },
    "ValueGrouper": {
      "properties": {
        "index_name": {
          "title": "Category",
          "type": "string"
        }
      },
      "required": [
        "index_name"
      ],
      "title": "Category",
      "type": "object"
    },
    "CustomMetric": {
      "dependencies": {
        "convert_units": {
          "oneOf": [
            {
              "properties": {
                "convert_units": {
                  "const": false
                }
              }
            },
            {
              "properties": {
                "convert_units": {
                  "const": true
                },
                "original_unit": {
                  "oneOf": [
                    {
                      "const": "m",
                      "title": "Meters (m)"
                    },
                    {
                      "const": "km",
                      "title": "Kilometers (km)"
                    },
                    {
                      "const": "m\u00b2",
                      "title": "Square Meters (m\u00b2)"
                    },
                    {
                      "const": "km\u00b2",
                      "title": "Square Kilometers (km\u00b2)"
                    },
                    {
                      "const": "s",
                      "title": "Seconds (s)"
                    },
                    {
                      "const": "h",
                      "title": "Hours (h)"
                    },
                    {
                      "const": "d",
                      "title": "Days (d)"
                    },
                    {
                      "const": "m/s",
                      "title": "Meters per Second (m/s)"
                    },
                    {
                      "const": "km/h",
                      "title": "Kilometers per Hour (km/h)"
                    }
                  ],
                  "title": "Original Unit",
                  "type": "string"
                },
                "new_unit": {
                  "oneOf": [
                    {
                      "const": "m",
                      "title": "Meters (m)"
                    },
                    {
                      "const": "km",
                      "title": "Kilometers (km)"
                    },
                    {
                      "const": "m\u00b2",
                      "title": "Square Meters (m\u00b2)"
                    },
                    {
                      "const": "km\u00b2",
                      "title": "Square Kilometers (km\u00b2)"
                    },
                    {
                      "const": "s",
                      "title": "Seconds (s)"
                    },
                    {
                      "const": "h",
                      "title": "Hours (h)"
                    },
                    {
                      "const": "d",
                      "title": "Days (d)"
                    },
                    {
                      "const": "m/s",
                      "title": "Meters per Second (m/s)"
                    },
                    {
                      "const": "km/h",
                      "title": "Kilometers per Hour (km/h)"
                    }
                  ],
                  "title": "New Unit",
                  "type": "string"
                }
              }
            }
          ]
        }
      },
      "description": "Define your own metric: pick a column and statistic, with optional unit conversion.",
      "properties": {
        "display_name": {
          "description": "Column header shown in the summary table.",
          "title": "Display Name",
          "type": "string"
        },
        "aggregator": {
          "enum": [
            "sum",
            "count",
            "min",
            "max",
            "mean",
            "nunique",
            "median"
          ],
          "title": "Statistic",
          "type": "string"
        },
        "column": {
          "description": "Column to aggregate.",
          "title": "Column",
          "type": "string"
        },
        "decimal_places": {
          "default": 2,
          "title": "Decimal Places",
          "type": "integer"
        },
        "convert_units": {
          "default": false,
          "title": "Convert Units",
          "type": "boolean"
        },
        "metric": {
          "const": "custom",
          "default": "custom",
          "enum": [
            "custom"
          ],
          "title": "Metric",
          "type": "string"
        }
      },
      "required": [
        "display_name",
        "aggregator",
        "column"
      ],
      "title": "Custom",
      "type": "object"
    },
    "MergedAreaCoveredMetric": {
      "description": "Area covered with overlaps counted once \u2014 the distinct ground footprint.",
      "properties": {
        "metric": {
          "const": "area_covered_merged",
          "default": "area_covered_merged",
          "enum": [
            "area_covered_merged"
          ],
          "title": "Metric",
          "type": "string"
        },
        "swath_width_meters": {
          "default": 500.0,
          "description": "Full corridor width in meters.",
          "title": "Swath Width (m)",
          "type": "number"
        }
      },
      "title": "Area Covered (Merged)",
      "type": "object"
    },
    "PatrolCountMetric": {
      "properties": {
        "metric": {
          "const": "patrol_count",
          "default": "patrol_count",
          "enum": [
            "patrol_count"
          ],
          "title": "Metric",
          "type": "string"
        }
      },
      "title": "Patrol Count",
      "type": "object"
    },
    "PatrolDaysMetric": {
      "properties": {
        "metric": {
          "const": "patrol_days",
          "default": "patrol_days",
          "enum": [
            "patrol_days"
          ],
          "title": "Metric",
          "type": "string"
        }
      },
      "title": "Patrol Days",
      "type": "object"
    },
    "TotalDistanceMetric": {
      "properties": {
        "metric": {
          "const": "total_distance",
          "default": "total_distance",
          "enum": [
            "total_distance"
          ],
          "title": "Metric",
          "type": "string"
        },
        "unit": {
          "default": "km",
          "oneOf": [
            {
              "const": "km",
              "title": "Kilometers (km)"
            },
            {
              "const": "m",
              "title": "Meters (m)"
            }
          ],
          "title": "Unit",
          "type": "string"
        }
      },
      "title": "Total Distance",
      "type": "object"
    },
    "TotalDurationMetric": {
      "properties": {
        "metric": {
          "const": "total_duration",
          "default": "total_duration",
          "enum": [
            "total_duration"
          ],
          "title": "Metric",
          "type": "string"
        },
        "unit": {
          "default": "h",
          "oneOf": [
            {
              "const": "h",
              "title": "Hours (h)"
            },
            {
              "const": "d",
              "title": "Days (d)"
            }
          ],
          "title": "Unit",
          "type": "string"
        }
      },
      "title": "Total Duration",
      "type": "object"
    },
    "UnmergedAreaCoveredMetric": {
      "description": "Area covered summed segment by segment \u2014 total patrol efforts.",
      "properties": {
        "metric": {
          "const": "area_covered_unmerged",
          "default": "area_covered_unmerged",
          "enum": [
            "area_covered_unmerged"
          ],
          "title": "Metric",
          "type": "string"
        },
        "swath_width_meters": {
          "default": 500.0,
          "description": "Full corridor width in meters.",
          "title": "Swath Width (m)",
          "type": "number"
        }
      },
      "title": "Area Covered (Unmerged)",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone"
      ]
    },
    "er_patrol_params": {
      "ui:order": [
        "patrol_types",
        "status",
        "patrols_overlap_daterange"
      ]
    },
    "patrol_filters": {
      "ui:order": [
        "bounding_box",
        "filter_point_coords",
        "trajectory_segment_filter"
      ]
    },
    "ui:order": [
      "workflow_details",
      "er_client_name",
      "time_range",
      "er_patrol_params",
      "patrol_filters",
      "groupers",
      "summary_groupby",
      "summary_metrics"
    ]
  },
  "additionalProperties": false
}
